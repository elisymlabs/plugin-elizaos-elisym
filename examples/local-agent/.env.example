# Required - ElizaOS agent needs an LLM for its own reasoning loop.
ANTHROPIC_API_KEY=

# SECRET_SALT is the KDF salt for ElizaOS encryption-at-rest. In production,
# generate a random value (e.g. `openssl rand -hex 32`) and load it from your
# secret manager. The plugin refuses to start on mainnet (or as a provider
# with a configured private key) without this set to a non-default value.
SECRET_SALT=local-dev-only-change-me-in-prod

# ELIZA_SERVER_AUTH_TOKEN guards the ElizaOS HTTP API. Required in production
# alongside SECRET_SALT under the same conditions as above.
# ELIZA_SERVER_AUTH_TOKEN=local-dev-only-token

# ELISYM_ALLOW_UNSECURED_RUNTIME=true downgrades the SECRET_SALT / auth-token
# start-time error to a one-shot WARN. ONLY for local dev. Never set in prod.
# ELISYM_ALLOW_UNSECURED_RUNTIME=true

# Pin Claude model IDs. Haiku 4.5 is the latest 2025 Haiku; the plugin-anthropic
# default (claude-3-5-haiku-20241022) has been retired by Anthropic and causes
# "model: claude-3-5-haiku-20241022" errors when the provider processes a job.
ANTHROPIC_SMALL_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_LARGE_MODEL=claude-haiku-4-5-20251001

# Optional - customise logging. "debug" surfaces every NIP-90/Solana event.
LOG_LEVEL=info

# Optional overrides - normally ELISYM_* come from the character file,
# but env wins if both are set.
# ELISYM_RELAYS=wss://relay.damus.io,wss://nos.lol
# ELISYM_SOLANA_RPC_URL=https://api.devnet.solana.com
