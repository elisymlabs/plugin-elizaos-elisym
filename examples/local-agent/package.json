{
  "name": "elisym-local-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "true",
    "start:provider": "elizaos start --character ./provider.character.json",
    "start:provider-youtube": "elizaos start --character ./provider-youtube.character.json",
    "start:provider-trending": "elizaos start --character ./provider-trending.character.json",
    "db:inspect": "bun run scripts/db-inspect.ts",
    "db:clear": "bun run scripts/db-clear.ts"
  },
  "dependencies": {
    "@elisym/plugin-elizaos": "~0.3.0",
    "@elizaos/cli": "~1.7.2",
    "@elizaos/plugin-anthropic": "~1.5.12",
    "@elizaos/plugin-bootstrap": "~1.7.2",
    "@elizaos/plugin-sql": "~1.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
